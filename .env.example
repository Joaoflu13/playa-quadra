# Copie para .env e preencha. Valores reais: painel da Vercel (Settings → Environment
# Variables) ou Supabase. NÃO commite o .env.

# Postgres POOLED (Supabase 6543, com pgbouncer). Usado pelo app.
DATABASE_URL="postgresql://USER:PASSWORD@HOST.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Postgres DIRETO/SESSION (Supabase 5432). Usado por prisma db push / seed.
DIRECT_URL="postgresql://USER:PASSWORD@HOST.pooler.supabase.com:5432/postgres"

# Segredo da sessão (gere com: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
AUTH_SECRET="troque-por-um-segredo"
AUTH_TRUST_HOST="true"

# Protege o cron de lembretes
CRON_SECRET="troque-por-um-segredo"

# URL pública (links de e-mail). Local: http://localhost:3000
APP_URL="http://localhost:3000"

# E-mail (opcional) — sem isso, e-mails ficam em fallback (logam, não enviam)
# RESEND_API_KEY="re_..."
# EMAIL_FROM="Quadra <reservas@seudominio.com>"
