generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // URL pooled (Neon ...-pooler) usada pelo app em runtime serverless.
  url      = env("DATABASE_URL")
  // URL direta (sem pooler) usada por migrate/db push. No Neon é a
  // connection string sem "-pooler". Se você usar a mesma, omita esta linha.
  directUrl = env("DIRECT_URL")
}

enum Role {
  RESIDENT
  ADMIN
}

enum AptStatus {
  ACTIVE
  SUSPENDED
}

enum BookingStatus {
  CONFIRMED
  CANCELLED
  NO_SHOW // usado a partir do V1
  DONE
}

/// A conta é o MORADOR (1 login por pessoa). Login pelo CPF.
/// Mantém o nome "Apartment" e o campo "aptId" nas relações para não quebrar
/// o histórico de dados; semanticamente, hoje, representa um morador.
model Apartment {
  id           String     @id @default(cuid())
  cpf          String     @unique // login (só dígitos)
  label        String     // nome de exibição do morador, ex "João Silva"
  unit         String     @default("") // unidade, ex "Bloco A - 304"
  email        String?    @unique // opcional, para confirmação/lembrete
  passwordHash String
  role         Role       @default(RESIDENT)
  status       AptStatus  @default(ACTIVE)
  blockedUntil DateTime?  // bloqueio temporário por falta (no-show)
  // Primeiro acesso: nasce true; força troca de senha antes de usar o app.
  mustChangePassword Boolean @default(true)
  // Auto-cadastro: null = pré-autorizado mas ainda não ativado pelo morador.
  // Preenchido quando o morador ativa a conta (cria a própria senha) ou quando
  // o síndico cria a conta já com senha. Contas antigas recebem o createdAt.
  activatedAt  DateTime?
  createdAt    DateTime   @default(now())
  bookings     Booking[]
  penalties    Penalty[]
  interests    JoinInterest[]
  notifications Notification[]
  resetTokens  PasswordResetToken[]
  recurrings   RecurringBooking[]
  waitlist     Waitlist[]
  openMatches  OpenMatch[]
}

/// "Jogo aberto": um morador procura parceiro num horário, SEM reservar a quadra.
/// O slot continua livre (qualquer um pode reservar sozinho). Quando outro morador
/// entra ("Eu quero"), vira uma reserva confirmada para a dupla e o OpenMatch some.
model OpenMatch {
  id        String    @id @default(cuid())
  courtId   String
  startAt   DateTime
  aptId     String // quem está procurando parceiro
  apartment Apartment @relation(fields: [aptId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@unique([courtId, startAt]) // um jogo aberto por horário
  @@index([aptId])
}

/// Lista de espera de um horário ocupado. É ancorada ao SLOT (courtId+startAt),
/// não à reserva, para sobreviver ao cancelamento. Quando o dono cancela, todos
/// os moradores da fila são avisados (notificação) e o primeiro a reservar leva.
model Waitlist {
  id        String    @id @default(cuid())
  courtId   String
  startAt   DateTime
  aptId     String
  apartment Apartment @relation(fields: [aptId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  // Um morador só entra uma vez na fila do mesmo slot.
  @@unique([courtId, startAt, aptId])
  @@index([courtId, startAt])
  @@index([aptId])
}

/// Token de redefinição de senha (esqueci minha senha). Expira em ~1h.
model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique
  aptId     String
  apartment Apartment @relation(fields: [aptId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime  @default(now())

  @@index([aptId])
}

/// Notificação in-app para um morador (ex.: alguém demonstrou interesse).
model Notification {
  id        String    @id @default(cuid())
  aptId     String
  apartment Apartment @relation(fields: [aptId], references: [id], onDelete: Cascade)
  type      String    // INTEREST | INTEREST_REMOVED | ...
  message   String
  bookingId String?
  read      Boolean   @default(false)
  createdAt DateTime  @default(now())

  @@index([aptId, read])
}

/// Única hoje; modelada como tabela para abrir multi-quadra no V2 sem migração disruptiva.
model Court {
  id         String       @id @default(cuid())
  name       String
  bookings   Booking[]
  blocks     CourtBlock[]
  recurrings RecurringBooking[]
}

/// Bloqueio da quadra pelo síndico (manutenção, torneio, chuva, evento).
/// Nenhum morador pode reservar slots que caiam dentro do intervalo.
model CourtBlock {
  id        String   @id @default(cuid())
  courtId   String
  court     Court    @relation(fields: [courtId], references: [id])
  startAt   DateTime
  endAt     DateTime
  reason    String   // ex.: "Manutenção", "Torneio interno"
  createdAt DateTime @default(now())

  @@index([courtId, startAt])
}

/// Reserva fixa/recorrente (ex.: aula de tênis no mesmo horário toda semana).
/// O síndico cadastra; o sistema materializa reservas concretas para as
/// próximas semanas. weekday/hour são em horário local de São Paulo.
model RecurringBooking {
  id        String    @id @default(cuid())
  courtId   String
  court     Court     @relation(fields: [courtId], references: [id])
  aptId     String
  apartment Apartment @relation(fields: [aptId], references: [id])
  weekday   Int       // 0=domingo … 6=sábado
  hour      Int       // hora local de início (ex.: 19)
  createdAt DateTime  @default(now())

  @@unique([courtId, weekday, hour])
  @@index([aptId])
}

model Booking {
  id        String        @id @default(cuid())
  courtId   String
  court     Court         @relation(fields: [courtId], references: [id])
  aptId     String
  apartment Apartment     @relation(fields: [aptId], references: [id])
  startAt   DateTime
  endAt     DateTime
  status    BookingStatus @default(CONFIRMED)
  createdAt DateTime      @default(now())
  // Marca quando o e-mail de lembrete foi enviado (evita duplicar no cron).
  reminderSentAt DateTime?
  // "Procuro parceiros": dono abre o horário p/ outros sinalizarem interesse.
  openForPlayers Boolean   @default(false)
  interests JoinInterest[]

  // Trava de integridade: um morador não reserva o mesmo slot duas vezes.
  // Áreas com capacidade > 1 (ex.: Sala de Pilates, 2 vagas) admitem vários
  // moradores no mesmo slot; o limite de vagas é validado na transação
  // (count sob isolamento Serializable). Áreas de capacidade 1 (tênis, sinuca)
  // ficam efetivamente com 1 reserva por slot por causa desse mesmo count.
  @@unique([courtId, startAt, aptId])
  @@index([courtId, startAt])
  @@index([aptId, startAt])
  @@index([startAt])
}

/// Interesse de um morador em jogar numa reserva aberta ("procuro parceiros").
model JoinInterest {
  id        String    @id @default(cuid())
  bookingId String
  booking   Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  aptId     String
  apartment Apartment @relation(fields: [aptId], references: [id])
  createdAt DateTime  @default(now())

  // Um morador só sinaliza interesse uma vez por reserva.
  @@unique([bookingId, aptId])
  @@index([bookingId])
}

/// Singleton (id = 1). Editável pelo admin sem redeploy.
model RuleConfig {
  id                 Int @id @default(1)
  slotMinutes        Int @default(60)
  openHour           Int @default(8)
  closeHour          Int @default(22)
  advanceHours       Int @default(24) // janela de reserva em HORAS (ex.: 24 = pode reservar com até 24h de antecedência)
  maxActivePerApt    Int @default(2)
  maxWeeklyPerApt    Int @default(3)
  cancelMinNoticeMin Int @default(120)
  noShowBlockDays    Int @default(7) // dias de bloqueio por falta
}

/// Controle de tentativas de login/ativação — substitui o Map in-memory do rateLimit.ts.
/// Chave: namespace + identificador (ex.: "login:12345678900", "ativar:12345678900").
/// Persiste entre restarts e é compartilhado entre instâncias serverless.
model RateLimit {
  key         String    @id          // namespace:cpf
  fails       Int       @default(0)
  firstAt     DateTime
  lockedUntil DateTime?
}

/// V1 — rastreio de no-show / late-cancel para suspensão automática.
model Penalty {
  id        String    @id @default(cuid())
  aptId     String
  apartment Apartment @relation(fields: [aptId], references: [id])
  reason    String // NO_SHOW | LATE_CANCEL
  createdAt DateTime  @default(now())
}
